# https://editorconfig.org/

root = true

[*]
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf
charset = utf-8

# Python files
[*.py]
max_line_length = 119

# Web files (HTML, CSS, JavaScript, TypeScript)
[*.{html,css,scss,sass,less}]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

# Vue.js files
[*.vue]
indent_size = 2
max_line_length = 100

# Configuration files
[*.{json,jsonc}]
indent_size = 2
insert_final_newline = ignore

[*.{yml,yaml}]
indent_size = 2

[*.toml]
indent_size = 2

# Docker files
[{Dockerfile*,*.dockerfile}]
indent_size = 2

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 2

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

# Documentation
[docs/**.txt]
max_line_length = 79

# Makefiles always use tabs for indentation
[{Makefile,makefile,*.mk}]
indent_style = tab

# Batch files use tabs for indentation
[*.bat]
indent_style = tab

# Ignore vendor and generated files
[**/node_modules/**]
indent_style = ignore
indent_size = ignore

[**/admin/js/vendor/**]
indent_style = ignore
indent_size = ignore

[**.min.{js,css}]
indent_style = ignore
insert_final_newline = ignore

# Environment files
[.env*]
insert_final_newline = true
