{
  "name": "nuxt-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node .output/server/index.mjs",
    "build": "pnpm nuxt:prepare && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "nuxt:prepare": "nuxi prepare",
    "format:check": "prettier --check .",
    "format:write": "prettier --write --list-different .",
    "lint": "eslint . --fix",
    "typescript:check": "pnpm nuxi typecheck"
  },
  "lint-staged": {
    "*": [
      "eslint --fix"
    ],
    "*.{vue,js,ts,jsx,tsx,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/robots": "^5.7.1",
    "@pinia/nuxt": "^0.11.3",
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-query": "^5.92.9",
    "@tanstack/vue-query-devtools": "^6.1.5",
    "@unhead/vue": "^2.1.12",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "^10.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "vue3-toastify": "^0.2.9",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@primevue/nuxt-module": "^4.5.4",
    "@tanstack/eslint-plugin-query": "^5.100.9",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
