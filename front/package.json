{
  "name": "nuxt-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node .output/server/index.mjs",
    "build": "pnpm nuxt:prepare && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "nuxt:prepare": "nuxi prepare",
    "format:check": "prettier --check .",
    "format:write": "prettier --write --list-different .",
    "lint": "eslint . --fix"
  },
  "lint-staged": {
    "*": [
      "eslint --fix"
    ],
    "*.{vue,js,ts,jsx,tsx,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nuxt/eslint": "^1.3.0",
    "@nuxt/fonts": "^0.11.0",
    "@nuxt/image": "^1.10.0",
    "@nuxtjs/i18n": "^9.5.4",
    "@nuxtjs/robots": "^5.2.10",
    "@pinia/nuxt": "^0.11.0",
    "@primeuix/themes": "^1.1.1",
    "@primevue/forms": "^4.3.4",
    "@tailwindcss/vite": "^4.1.1",
    "@tanstack/vue-query": "^5.90.5",
    "@tanstack/vue-query-devtools": "^5.91.0",
    "@unhead/vue": "^2.0.10",
    "@vueuse/core": "^13.4.0",
    "@vueuse/nuxt": "^13.1.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.0",
    "nuxt": "^3.20.1",
    "pinia": "^3.0.2",
    "primeicons": "^7.0.0",
    "primevue": "^4.4.1",
    "tailwind-merge": "^3.1.0",
    "tailwindcss": "^4.1.1",
    "tw-animate-css": "^1.2.5",
    "vue": "^3.5.24",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.1",
    "vue-sonner": "^1.3.0",
    "vue3-toastify": "^0.2.8",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@primevue/nuxt-module": "^4.4.1",
    "@tanstack/eslint-plugin-query": "^5.72.0",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "esbuild": "^0.24.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
