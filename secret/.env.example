# back
ENV="local"

BACKEND_CORS_ORIGINS=["http://localhost:8000", "https://localhost:8000", "http://localhost", "https://localhost", "http://localhost:3000"]

PROJECT_NAME="Template"

JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-32chars-minimum"
TIMEZONE="UTC"

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATE_LIMIT_BURST_SIZE=10

# Security Configuration
ENABLE_REQUEST_LOGGING=true
ENABLE_INPUT_VALIDATION=true
ENABLE_SECURITY_HEADERS=true

DB_USER="tmp_user"
DB_PASS="tmp_password"
DB_HOST="172.17.0.1" # host.docker.internal
DB_NAME="tmp_local"

# front
NUXT_PUBLIC_API_BASE="http://localhost:8000/api/v1"
